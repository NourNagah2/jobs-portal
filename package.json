{
    "name": "web-boilerplate",
    "version": "4.0.0",
    "private": true,
    "workspaces": [
        "_core",
        "apps/*"
    ],
    "scripts": {
        "simple": "             pnpm --filter @web-boilerplate/1-simple dev",
        "translations": "       pnpm --filter @web-boilerplate/2-translations dev",
        "tailwind": "           pnpm --filter @web-boilerplate/3-tailwind dev",
        "tanstack": "           pnpm --filter @web-boilerplate/4-tanstack dev",
        "buildall": "           pnpm -r run build",
        "lint": "               biome check .",
        "lint:fix": "biome check . --write",
        "format": "biome format . --write"
    },
    "bigalog": "              pnpm --filter @com/bigalog    dev",
    "dependencies": {
        "babel-plugin-react-compiler": "^19.0.0-beta-e552027-20250112",
        "clsx": "^2.1.1",
        "core": "workspace:core",
        "i18next": "^23.12.2",
        "i18next-browser-languagedetector": "^8.0.0",
        "i18next-fs-backend": "^2.3.1",
        "i18next-resources-to-backend": "^1.2.1",
        "next": "^16.0.7",
        "next-i18next": "^15.3.0",
        "react": "^19.2.1",
        "react-dom": "^19.2.1",
        "react-i18next": "^15.0.0",
        "universal-cookie": "^7.2.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.3",
        "@tailwindcss/postcss": "^4.1.13",
        "@types/node": "^20",
        "@types/react": "^19.2.3",
        "@types/react-dom": "^19.2.3",
        "autoprefixer": "^10.4.21",
        "postcss": "^8.5.6",
        "postcss-flexbugs-fixes": "^5.0.2",
        "postcss-preset-env": "^9.6.0",
        "postcss-rtl": "^2.0.0",
        "sass": "^1.77.8",
        "tailwindcss": "^4.1.13",
        "typescript": "^5"
    },
    "engines": {
        "node": ">=18.12.0",
        "bun": "use pnpm please",
        "npm": "use pnpm please",
        "yarn": "use pnpm please"
    },
    "packageManager": "pnpm@10.27.0",
    "overrides": {
        "@types/react": "^19.2.3",
        "@types/react-dom": "^19.2.3",
        "react-server-dom-webpack": "^19.2.3",
        "react-server-dom-parcel": "^19.2.3",
        "react-server-dom-turbopack": "^19.2.3"
    }
}
